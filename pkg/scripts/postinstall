#!/bin/bash
#
# postinstall - runs as root after .pkg payload is laid down.
#
# Jobs:
#   1. Ensure correct permissions on the CUPS filter.
#   2. Reload CUPS so it picks up the new filter + PPD.
#   3. Auto-detect a connected Deli thermal printer via lpinfo and
#      create a CUPS queue for it.
#   4. Log everything to /var/log/install.log.
#
# Fails are non-fatal for the auto-queue step so that users without
# the printer currently plugged in still get a successful install.

set -u
LOG="/var/log/install.log"
FILTER_BIN="/usr/libexec/cups/filter/rastertotspl"
PPD_FILE="/Library/Printers/PPDs/Contents/Resources/deli-dl888d-pro.ppd"
PRINTER_NAME="Deli_DL888D_PRO"

log() { echo "[deli-driver] $*" | tee -a "$LOG" ; }

log "postinstall starting"

# 1) Permissions
if [[ -f "$FILTER_BIN" ]]; then
    chown root:wheel "$FILTER_BIN"
    chmod 0755       "$FILTER_BIN"
    log "filter installed: $FILTER_BIN"
else
    log "ERROR: filter not found at $FILTER_BIN"
    exit 1
fi

if [[ -f "$PPD_FILE" ]]; then
    chown root:wheel "$PPD_FILE"
    chmod 0644       "$PPD_FILE"
    log "PPD installed: $PPD_FILE"
else
    log "ERROR: PPD not found at $PPD_FILE"
    exit 1
fi

# 2) Reload CUPS
log "reloading CUPS"
launchctl kickstart -k system/org.cups.cupsd 2>>"$LOG" || \
    log "WARN: CUPS reload via launchctl failed"
sleep 1

# 3) Auto-detect Deli printer
log "scanning USB for Deli printer (lpinfo -v)"
URI="$(/usr/sbin/lpinfo -v 2>/dev/null \
        | awk '/^direct usb:\/\// { print $2 }' \
        | grep -iE 'deli|dl[-_]?8[0-9]{2}' \
        | head -n1 || true)"

if [[ -z "${URI:-}" ]]; then
    log "INFO: no Deli printer currently connected — skipping auto-add"
    log "      run /Applications/Deli-Printer/add-printer.command later"
    exit 0
fi
log "detected URI: $URI"

# 4) (Re)create queue
if /usr/bin/lpstat -p "$PRINTER_NAME" >/dev/null 2>&1 ; then
    log "existing queue $PRINTER_NAME found — removing before re-adding"
    /usr/sbin/lpadmin -x "$PRINTER_NAME" 2>>"$LOG" || true
fi

/usr/sbin/lpadmin -p "$PRINTER_NAME" -E \
    -v "$URI" \
    -P "$PPD_FILE" \
    -o printer-is-shared=false \
    -o media=w288h432 \
    2>>"$LOG"

if [[ $? -eq 0 ]]; then
    /usr/bin/cupsenable   "$PRINTER_NAME" 2>>"$LOG" || true
    /usr/sbin/cupsaccept  "$PRINTER_NAME" 2>>"$LOG" || true
    log "queue $PRINTER_NAME created successfully"
else
    log "ERROR: lpadmin failed to add queue"
fi

log "postinstall done"
exit 0
